    "map_tweaks": {
        // Spaceport (E2M1 / CQ2M1)
        "E2M1":{
            // This map has no normal exit.
            "metadata": { "allow_secret_exits": true }
        },

        // Chex Museum (E2M6 / CQ2M3)
        "E2M6":{
            "linedefs":{
                // Need to be able to escape from the blue section after teleporting from yellow.
                "300": {"upper": "BIGDOOR1", "special": 1}
            }
        },

        // Sewer System (E2M8 / CQ2M5)
        "E2M8":{
            "things":{
                // A voodoo doll is used to end the level; make it behave silently and discard the items it would pick up.
                "0": {"voodoo_ignore_damage": true, "voodoo_ignore_items": true},
                "201": {"dont_randomize": true},
                "202": {"dont_randomize": true},
                "203": {"dont_randomize": true},
                "204": {"dont_randomize": true},
                "210": {"dont_randomize": true}
            }
        },

        // United Cereals (E3M2 / CQ3M2)
        "E3M2":{
            // This map has no normal exit.
            "metadata": { "allow_secret_exits": true }
        },

        // Meteor Spaceship (E3M8 / CQ3M5)
        "E3M8":{
            "linedefs":{
                // We need to be able to leave Lord Snotfolus's lair.
                "949": {"special": 1}
            }
        }
    },

