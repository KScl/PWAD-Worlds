    "world_info":{
        "world_options":[
            {
                "name": "Difficulty",
                "skill_5_warning": "Careful, this will be tough. Do you wish to continue?",
                "list":[
                    {"full_name": "Easy does it", "description":"Damage taken is halved. Zorch received from pickups is doubled.", "aliases": ["itytd"]},
                    {"full_name": "Not so sticky", "description":"Lesser number or strength of Flemoids, and more pickups.", "aliases": ["hntr"]},
                    {"full_name": "Gobs of goo", "description":"The default skill. Balanced Flemoids and pickups.", "aliases": ["hmp"]},
                    {"full_name": "Extreme ooze", "description":"Greater number or strength of Flemoids, and less pickups.", "aliases": ["uv"]},
                    {"full_name": "Super slimey!", "description":"Flemoids are faster and more aggressive.", "option_name": "super slimey", "aliases": ["nm"]}
                ]
            },
            {"name": "Start with Maps" },
            {
                "name": "Custom Option",
                "type": "Toggle",
                "display_name": "Add Super Large Zorcher",
                "description":[
                    "If enabled, the Super Large Zorcher will be added to be item pool,",
                    "even though it is not normally obtainable."
                ]
            },
            {"name": "Capacity Upgrades" },
            {"name": "Custom Ammo Capacity" }
        ],
        "hooks":{
            "create_items":[
                "if self.options.add_super_large_zorcher.value:",
                "    slz_items = list(self.matching_items(doom_type=82).values())",
                "    itempool += [i.name for i in slz_items]"
            ]
        },
